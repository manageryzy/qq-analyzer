# Copy to .env.local for private local settings. Do not commit .env.local.

# Workspace root that contains the account data directories.
QQ_ANALYZER_ROOT=<WORKSPACE_ROOT>

# Optional default account. Use a placeholder in committed docs/config.
QQ_ANALYZER_ACCOUNT=<ACCOUNT_UIN>

# Optional web service bind address.
QQ_ANALYZER_HOST=127.0.0.1
QQ_ANALYZER_PORT=8765

# Optional Frida executable override. If unset, the Rust tool can download a
# cached frida-inject dependency under output/<account>/deps/frida/.
QQ_ANALYZER_FRIDA=<PATH_TO_FRIDA_INJECT>

# Optional Ghidra bridge settings for local reverse-engineering verification.
GHIDRA_MCP_URL=http://127.0.0.1:8089
GHIDRA_MCP_BRIDGE=<PATH_TO_BRIDGE_MCP_GHIDRA_PY>
QQ_ANALYZER_IM_DLL=<PATH_TO_PC_QQ_IM_DLL>

# Optional credential overrides. Prefer credentials.jsonl generated by
# qq_analyzer_rs capture all; do not put real keys in committed files.
PCQQ_INFOSTORAGE_KEY_HEX=<HEX_KEY>
